# 环境变量配置（复制为 backend/.env 后修改）

# 项目基础
# 路径字段支持相对路径；相对路径按 backend/.env 所在目录解析。
PROJECT_NAME=FBM Pipeline
VERSION=0.1.0
DEBUG=true
DATA_DIR=../data
# 必填：项目使用 MySQL，不再提供本地文件数据库 fallback。
DATABASE_URL=mysql+asyncmy://root@127.0.0.1:3306/fbm_pipeline?charset=utf8mb4
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8190
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=3190
PRODUCT_BASE_DIR=../data/products
DEFAULT_BRAND=Vindhvisk

# 本地安全/启动边界
# 默认只允许本机 mutating API；远程调试时设置 API_DEV_TOKEN，并通过 X-FBM-Dev-Token 或 Authorization: Bearer 传入。
API_DEV_TOKEN=
# 普通 API startup 默认不执行 DDL/backfill/recover/kick。需要维护时显式开启。
STARTUP_RUN_DB_MAINTENANCE=false
STARTUP_RUN_BACKFILLS=false
STARTUP_RECOVER_TASKS=false
STARTUP_KICK_TASK_RUNTIME=false
# 外部 token 请求默认校验证书；私有代理使用 CA bundle，不要默认关闭 TLS。
EXTERNAL_HTTP_VERIFY_TLS=true
EXTERNAL_HTTP_CA_BUNDLE=
# 图片代理默认只开放 PRODUCT_BASE_DIR；额外根目录用逗号分隔显式配置。
IMAGE_PROXY_EXTRA_ROOTS=

# LLM API（Listing / A+ 规划 / A+ 脚本）
LLM_API_BASE=https://sub2api.127space.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-5.5

# VLM API（主图分析；默认复用 LLM API 的 GPT-5.5 多模态能力）
VLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
VLM_API_KEY=
VLM_MODEL=gpt-5.5
VLM_USE_LLM_API=true

# GPT Image API（A+ 出图）
GPT_IMAGE_API_BASE=https://ai.t8star.cn/v1
GPT_IMAGE_API_KEY=
GPT_IMAGE_MODEL=gpt-image-2
GPT_IMAGE_USE_LLM_API=false
APLUS_IMAGE_API_MODE=edits
APLUS_IMAGE_GENERATION_QUALITY=high
APLUS_IMAGE_WIDTH=1940
APLUS_IMAGE_HEIGHT=1200
APLUS_IMAGE_ASPECT_RATIO=97:60
APLUS_IMAGE_MAX_BYTES=2000000
APLUS_IMAGE_JPEG_QUALITY=88
APLUS_IMAGE_MIN_JPEG_QUALITY=55
APLUS_IMAGE_API_RETRIES=3
APLUS_IMAGE_OVERWRITE_POLICY=skip_success
# A+ 自动触发默认关闭；A1 只提供 eligibility policy，不创建任务。
AUTO_APLUS_AFTER_EXPORT_READY=false
# 领星 A+ 发布工程线默认不允许真实外部调用；Listing sync 真实读取需显式开启。
LINGXING_APLUS_STORE_NAME=
LINGXING_APLUS_STORE_ID=
LINGXING_APLUS_SITE=US
LINGXING_LISTING_SYNC_ALLOW_REAL_EXTERNAL_CALLS=false
# T3 只保存领星 A+ 草稿；真实外部调用必须显式开启，默认不提交审批。
LINGXING_APLUS_ALLOW_REAL_EXTERNAL_CALLS=false
LINGXING_APLUS_SUBMIT_FOR_APPROVAL=false

# Pipeline 并发和步骤策略
PIPELINE_MAX_CONCURRENCY=2
BROWSER_WORKFLOW_CONCURRENCY=1
CHROME_LOCK_TIMEOUT=300
BULK_START_MAX_TASKS=100
STEP3_4_PARALLEL=true
STEP1_EXTRACT_RETRY_ATTEMPTS=5
STEP1_EXTRACT_RETRY_DELAY_SECONDS=3
STEP1_AFTER_READY_WAIT_SECONDS=1.0
STEP1_DOWNLOAD_TIMEOUT_SECONDS=300
STEP1_MATERIAL_PACKAGE_PRIORITY="To B素材包,Retail Ready素材包,Information"
STEP1_PRICE_MISSING_POLICY=manual_review
STEP1_MATERIAL_MISSING_POLICY=manual_review
STEP1_ALLOW_EXISTING_MATERIALS=true

# 定价
PRICING_NET_REVENUE_RATE=0.685
PRICING_TARGET_MARGIN_RATE=0.05
PRICING_MIN_PROFIT=10
PRICING_FIXED_COST=9
PRICING_RETURN_CREDIT_RATE=0.06

# Step 3 / Step 4
STEP3_MANUAL_LOGIN_ON_AUTH_FAILURE=true
STEP4_MISSING_ASIN_POLICY=manual_review
STEP4_CATEGORY_MISSING_POLICY=manual_review
STEP4_ALLOW_EXISTING_CATEGORY=true

# Step 5
STEP5_LLM_TEMPERATURE=0.7
STEP5_LLM_MAX_TOKENS=2000
STEP5_TITLE_MAX_CHARS=200
STEP5_BULLET_MAX_CHARS=500
STEP5_SEARCH_TERMS_MAX_BYTES=250

# A+ 出图并发
APLUS_CONCURRENCY=1
POLL_INTERVAL=3

# OSS 图片上传（Step 10 导入表格图片 URL）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=oss-us-west-1.aliyuncs.com
OSS_UPLOAD_PREFIX=main_image/
OSS_TEMPLATE_UPLOAD_PREFIX=category_templates/
OSS_SIGNED_URL_EXPIRES_SECONDS=2592000

# 卖家精灵
SELLERSPRITE_TOKEN=
SELLERSPRITE_OPENAPI_SECRET_KEY=

# GIGA Open API（大健云仓拉品）
# 店铺 API 地址、AK/SK、站点在「店铺维护」中配置，不再写入全局 .env。
GIGA_SYNC_PAGE_SIZE=200
